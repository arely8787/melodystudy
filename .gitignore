# ══════════════════════════════════════════════════════════════
#  MelodyStudy — .gitignore
# ══════════════════════════════════════════════════════════════

# ── Android (Gradle) ─────────────────────────────────────────
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/captures/
android/.externalNativeBuild/
android/.cxx/
android/*.apk
android/output.json
android/*.iml
android/.idea/
android/misc.xml
android/deploymentTargetDropDown.xml
android/render.experimental.xml
android/*.jks
android/*.keystore
android/google-services.json
android/*.hprof

# ── Backend Java (IntelliJ/Maven) ────────────────────────────
backend/.idea/
backend/*.iml
backend/target/
backend/audio_files/
backend/audio/

# Audios generados — no subir binarios al repo
backend/audio_files/
backend/temp_*.mp3
backend/cancion_*.mp3

# ── Python TTS ───────────────────────────────────────────────
tts/venv/
tts/__pycache__/
tts/*.pyc
tts/*.pyo
tts/*.pyd
tts/output_*.mp3

# ── Base de datos ─────────────────────────────────────────────
database/*.sql.bak

# ── Sistema operativo ─────────────────────────────────────────
.DS_Store
Thumbs.db
*.log